generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model nft {
  id            Int      @id @default(autoincrement())
  contract      String
  chainId       Int
  tokenId       String
  ownerWallet   String?
  rarity        String
  level         Int      @default(1)
  metadataUri   String
  lastSeenBlock Int
  lastTxHash    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@unique([contract, chainId, tokenId], map: "NFT_contract_chainId_tokenId_key")
}

model nonce {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  wallet    String
  value     String    @unique(map: "Nonce_value_key")
  expiresAt DateTime
  usedAt    DateTime?
}

model order {
  id          String         @id
  buyerWallet String
  priceEth    Decimal        @db.Decimal(38, 18)
  txHash      String?        @unique(map: "Order_txHash_key")
  itemType    order_itemType
  itemRef     Int?
  tokenId     String?
  rarity      String?
  status      String
  createdAt   DateTime       @default(now())
  user_slots  user_slots[]
}

model transaction {
  id        String   @id
  txHash    String   @unique(map: "Transaction_txHash_key")
  type      String
  from      String
  to        String
  contract  String
  chainId   Int
  tokenId   String?
  blockNum  Int
  blockTime DateTime
}

model user {
  id                   String           @id
  email                String?          @unique(map: "User_email_key")
  emailVerifiedAt      DateTime?
  displayName          String?
  country              String?
  isBlock              Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @default(now()) @updatedAt
  last_processus_bonus DateTime?        @db.DateTime(0)
  pack_purchases       pack_purchases[]
  user_rewards         user_rewards[]
  user_slots           user_slots[]
  wallet               wallet[]
}

model wallet {
  id        String   @id
  address   String   @unique(map: "Wallet_address_key")
  userId    String?
  isPrimary Boolean  @default(true)
  createdAt DateTime @default(now())
  user      user?    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Wallet_userId_fkey")

  @@index([userId], map: "Wallet_userId_fkey")
}

model syncstate {
  id        Int      @id @default(1)
  lastBlock Int
  updatedAt DateTime @default(now()) @db.Timestamp(0)
}

model loogs {
  idLog     Int      @id @default(autoincrement())
  addIP     String   @db.VarChar(30)
  status    String   @db.VarChar(250)
  createdAt DateTime @default(now()) @db.DateTime(0)
}

model wallet_connections {
  id         Int       @id @default(autoincrement())
  wallet     String    @db.VarChar(255)
  ip         String    @db.VarChar(50)
  status     String    @default("pending") @db.VarChar(20)
  created_at DateTime? @default(now()) @db.DateTime(0)
}

model pack_contents {
  id         Int                     @id @default(autoincrement())
  pack_id    Int
  item_type  pack_contents_item_type
  item_ref   Int
  quantity   Int?                    @default(1)
  created_at DateTime?               @default(now()) @db.DateTime(0)
  updated_at DateTime?               @default(now()) @db.DateTime(0)
  packs      packs                   @relation(fields: [pack_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_pack")

  @@index([pack_id], map: "fk_pack")
}

model pack_purchases {
  id              Int       @id @default(autoincrement())
  user_id         String
  pack_id         Int
  quantity        Int?      @default(1)
  total_usd       Decimal   @db.Decimal(10, 2)
  tx_hash         String    @unique(map: "tx_hash") @db.VarChar(255)
  purchased_at    DateTime? @default(now()) @db.DateTime(0)
  updated_at      DateTime? @default(now()) @db.DateTime(0)
  used_in_rewards Int       @default(0) @db.TinyInt
  packs           packs     @relation(fields: [pack_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_purchase_pack")
  user            user      @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_purchase_user")

  @@index([pack_id], map: "fk_purchase_pack")
  @@index([user_id], map: "fk_purchase_user")
}

model packs {
  id               Int              @id @default(autoincrement())
  name             String           @db.VarChar(255)
  description      String?          @db.Text
  price_usd        Decimal          @db.Decimal(10, 2)
  image_url        String?          @db.Text
  is_active        Boolean?         @default(true)
  limited_quantity Int?
  bonus_threshold  Boolean?         @default(false)
  created_at       DateTime?        @default(now()) @db.DateTime(0)
  updated_at       DateTime?        @default(now()) @db.DateTime(0)
  type             packs_type
  pack_contents    pack_contents[]
  pack_purchases   pack_purchases[]
}

model slots {
  id             Int          @id @default(autoincrement())
  level          Int          @db.TinyInt
  name           String       @db.VarChar(255)
  base_price_usd Decimal      @db.Decimal(10, 2)
  image_url      String?      @db.Text
  is_active      Boolean?     @default(true)
  is_sellable    Boolean?     @default(false)
  created_at     DateTime?    @default(now()) @db.DateTime(0)
  updated_at     DateTime?    @default(now()) @db.DateTime(0)
  user_slots     user_slots[]
}

model user_rewards {
  id           Int                      @id @default(autoincrement())
  user_id      String
  reward_type  user_rewards_reward_type
  reward_value String?                  @db.VarChar(255)
  claimed      Boolean?                 @default(false)
  generated_at DateTime?                @default(now()) @db.DateTime(0)
  updated_at   DateTime?                @default(now()) @db.DateTime(0)
  user         user                     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_reward_user")

  @@index([user_id], map: "fk_reward_user")
}

model user_slots {
  id                 Int                @id @default(autoincrement())
  user_id            String
  slot_type_id       Int
  status             user_slots_status? @default(available)
  bound_nft_id       Int?
  source_purchase_id Int?
  source_ordre_id    String?
  idempotency_key    String?            @db.VarChar(250)
  acquired_at        DateTime           @default(now()) @db.DateTime(0)
  updated_at         DateTime           @default(now()) @db.DateTime(0)
  slots              slots              @relation(fields: [slot_type_id], references: [id], map: "fk_us_slot_type")
  user               user               @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_user_slot")
  order              order?             @relation(fields: [source_ordre_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_user_slots_order")

  @@index([source_purchase_id], map: "fk_us_purchase")
  @@index([slot_type_id], map: "fk_us_slot_type")
  @@index([source_ordre_id], map: "fk_user_slots_order")
  @@index([user_id], map: "fk_user_slot")
}

model medias {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  url         String    @db.VarChar(255)
  type        String?   @db.VarChar(100)
  order_index Int
  createdAt   DateTime? @default(now()) @db.DateTime(0)
  ref         String?
}

model admin_logs {
  id         Int      @id @default(autoincrement())
  admin_id   Int
  action     String   @db.VarChar(255)
  entity_id  Int?
  details    String?  @db.Text
  created_at DateTime @default(now()) @db.DateTime(0)
  admins     admins   @relation(fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_admin_logs_admin")

  @@index([action], map: "idx_admin_logs_action")
  @@index([admin_id], map: "idx_admin_logs_admin_id")
}

model admins {
  id                     Int          @id @default(autoincrement())
  username               String       @unique(map: "username") @db.VarChar(100)
  email                  String       @unique(map: "email") @db.VarChar(100)
  password_hash          String?      @db.VarChar(255)
  role                   admins_role  @default(viewer)
  isActive               Boolean      @default(false)
  twofa_secret           String?      @db.VarChar(255)
  twofa_secret_createdAt DateTime?    @default(now()) @db.DateTime(0)
  created_at             DateTime     @default(now()) @db.DateTime(0)
  updated_at             DateTime     @default(now()) @db.DateTime(0)
  admin_logs             admin_logs[]
}

enum pack_contents_item_type {
  slot
  boost
  nft
  bonus
}

enum user_rewards_reward_type {
  nft
  boost
  early_access
}

enum packs_type {
  bronze
  silver
  gold
}

enum user_slots_status {
  available
  active
  locked
  archived
}

enum order_itemType {
  slot
  boost
  nft
  bonus
  pack
}

enum admins_role {
  superadmin
  admin
  manager
  viewer
}
